{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://military-history-elo.example/schemas/event.schema.json",
  "title": "Military History Elo canonical or legacy event",
  "description": "Compatibility-oriented event schema. Canonical evidence fields are optional data only and do not imply rating eligibility. Signed BCE/CE dates have no year zero and use the proleptic Gregorian calendar as a machine-readable convention.",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "name"],
  "dependentRequired": {
    "outcome_source_ids": ["outcome_source_family_ids"],
    "outcome_source_family_ids": ["outcome_source_ids"],
    "modern_location_country": ["location_provenance"],
    "location_provenance": ["hced_candidate_id"]
  },
  "allOf": [
    {
      "if": {"required": ["location_provenance"]},
      "then": {
        "anyOf": [
          {"required": ["modern_location_country"]},
          {"required": ["geometry"]}
        ]
      }
    },
    {
      "if": {"required": ["hced_candidate_id", "geometry"]},
      "then": {
        "required": ["location_provenance"],
        "properties": {
          "geometry": {"$ref": "#/$defs/hcedLocationPoint"}
        }
      }
    },
    {
      "if": {"required": ["hced_candidate_id"]},
      "then": {
        "required": ["source_ids"],
        "properties": {
          "source_ids": {"contains": {"const": "hced_dataset"}}
        }
      }
    },
    {
      "if": {
        "required": ["outcome_source_ids"],
        "properties": {
          "outcome_source_ids": {"contains": {"const": "hced_dataset"}}
        }
      },
      "then": {"required": ["hced_candidate_id"]}
    }
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
    "name": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
    "year": {"type": "integer"},
    "end_year": {"type": "integer"},
    "event_type": {"type": "string"},
    "war_type": {"type": "string"},
    "scale": {"type": "string"},
    "stakes": {"type": "string"},
    "decisiveness": {"type": "number"},
    "confidence": {"type": "number"},
    "participants": {
      "type": "array",
      "items": {"$ref": "#/$defs/legacyParticipant"}
    },
    "source_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": ".*\\S.*"}
    },
    "outcome_source_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^\\S(?:.*\\S)?$"
      }
    },
    "outcome_source_family_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^\\S(?:.*\\S)?$"
      }
    },
    "hced_candidate_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "modern_location_country": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "location_provenance": {"$ref": "#/$defs/locationProvenance"},
    "aliases": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "parent_event_id": {
      "anyOf": [
        {"type": "string", "pattern": ".*\\S.*"},
        {"type": "null"}
      ]
    },
    "parent_event_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
      "uniqueItems": true
    },
    "child_event_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
      "uniqueItems": true
    },
    "date_interval": {"$ref": "#/$defs/uncertainDateInterval"},
    "geometry": {"$ref": "#/$defs/geometry"},
    "participation_episodes": {
      "type": "array",
      "items": {"$ref": "#/$defs/participationEpisode"}
    },
    "claim_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
      "uniqueItems": true
    },
    "adjudication_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
      "uniqueItems": true
    },
    "layer": {"type": "string"},
    "domain": {"type": "string"},
    "region": {"type": "string"},
    "status": {"type": "string"}
  },
  "$defs": {
    "locationProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_record_id",
        "assertion_status",
        "coordinate_precision"
      ],
      "properties": {
        "source_id": {"const": "hced_dataset"},
        "source_record_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S(?:.*\\S)?$"
        },
        "assertion_status": {"const": "unreviewed_source_assertion"},
        "coordinate_precision": {"const": "unknown"}
      }
    },
    "hcedLocationPoint": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {"const": "Point"},
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {"type": "number", "minimum": -180, "maximum": 180},
            {"type": "number", "minimum": -90, "maximum": 90}
          ],
          "items": false
        }
      },
      "additionalProperties": false
    },
    "dateValue": {
      "oneOf": [
        {"type": "integer", "not": {"const": 0}},
        {
          "type": "string",
          "pattern": "^-?(?!0+(?:-|$))[0-9]{1,6}(?:-(?:0[1-9]|1[0-2])(?:-(?:0[1-9]|[12][0-9]|3[01]))?)?$"
        }
      ]
    },
    "uncertainDate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["low", "best", "high", "precision"],
      "properties": {
        "low": {"anyOf": [{"$ref": "#/$defs/dateValue"}, {"type": "null"}]},
        "best": {"anyOf": [{"$ref": "#/$defs/dateValue"}, {"type": "null"}]},
        "high": {"anyOf": [{"$ref": "#/$defs/dateValue"}, {"type": "null"}]},
        "precision": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"}
      },
      "anyOf": [
        {"properties": {"low": {"not": {"type": "null"}}}},
        {"properties": {"best": {"not": {"type": "null"}}}},
        {"properties": {"high": {"not": {"type": "null"}}}}
      ]
    },
    "uncertainDateInterval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"$ref": "#/$defs/uncertainDate"},
        "end": {"$ref": "#/$defs/uncertainDate"}
      }
    },
    "geometry": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "coordinates"],
          "properties": {
            "type": {"const": "Point"},
            "coordinates": {"$ref": "#/$defs/position"}
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["type", "coordinates"],
          "properties": {
            "type": {"const": "MultiPoint"},
            "coordinates": {
              "type": "array",
              "items": {"$ref": "#/$defs/position"}
            }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["type", "coordinates"],
          "properties": {
            "type": {"const": "LineString"},
            "coordinates": {"$ref": "#/$defs/lineStringCoordinates"}
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["type", "coordinates"],
          "properties": {
            "type": {"const": "MultiLineString"},
            "coordinates": {
              "type": "array",
              "items": {"$ref": "#/$defs/lineStringCoordinates"}
            }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["type", "coordinates"],
          "properties": {
            "type": {"const": "Polygon"},
            "coordinates": {"$ref": "#/$defs/polygonCoordinates"}
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["type", "coordinates"],
          "properties": {
            "type": {"const": "MultiPolygon"},
            "coordinates": {
              "type": "array",
              "items": {"$ref": "#/$defs/polygonCoordinates"}
            }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["type", "geometries"],
          "properties": {
            "type": {"const": "GeometryCollection"},
            "geometries": {
              "type": "array",
              "items": {"$ref": "#/$defs/geometry"}
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "position": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "number"}
    },
    "lineStringCoordinates": {
      "type": "array",
      "minItems": 2,
      "items": {"$ref": "#/$defs/position"}
    },
    "linearRing": {
      "type": "array",
      "minItems": 4,
      "items": {"$ref": "#/$defs/position"}
    },
    "polygonCoordinates": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/linearRing"}
    },
    "participationEpisode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "entity_id", "side", "role"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
        "entity_id": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
        "side": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
        "role": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
        "entry": {"$ref": "#/$defs/uncertainDate"},
        "exit": {"$ref": "#/$defs/uncertainDate"},
        "contribution": {"type": "number", "minimum": 0, "maximum": 1},
        "objectives": {"type": "array", "items": {"type": "string"}},
        "claim_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
          "uniqueItems": true
        }
      }
    },
    "legacyParticipant": {
      "type": "object",
      "additionalProperties": true,
      "required": ["entity_id", "side"],
      "properties": {
        "entity_id": {"type": "string", "pattern": ".*\\S.*"},
        "side": {"type": "string", "pattern": ".*\\S.*"},
        "role": {"type": "string"},
        "entry": {"$ref": "#/$defs/uncertainDate"},
        "exit": {"$ref": "#/$defs/uncertainDate"},
        "objectives": {"type": "array", "items": {"type": "string"}},
        "claim_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
          "uniqueItems": true
        },
        "adjudication_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
          "uniqueItems": true
        }
      }
    }
  }
}
